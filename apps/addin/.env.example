# Cellix Add-in Environment Variables
# Copy this file to .env.local for local development

# API URL (required in production, optional in development)
# In development: Leave empty to use Vite proxy (/api -> localhost:3001)
# In production: Set to full backend URL (e.g., https://api.cellix.app/api)
VITE_API_URL=

# Example production value:
# VITE_API_URL=https://api.cellix.app/api
