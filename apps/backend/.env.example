# Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# AI Provider (Required for Phase 3+)
# Option 1: Direct OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o

# Option 2: OpenRouter (recommended for flexibility/cost)
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
# Other model options:
# - openai/gpt-4o-mini (cheaper, faster)
# - anthropic/claude-3.5-sonnet (good alternative)
# - meta-llama/llama-3.1-70b-instruct (cheapest quality option)

# Supabase (Phase 4+)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
