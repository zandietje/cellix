{
  "name": "@cellix/addin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "setup:certs": "office-addin-dev-certs install --days 365",
    "start": "npm run setup:certs && npm run dev",
    "sideload": "office-addin-debugging start manifest.xml"
  },
  "dependencies": {
    "@cellix/shared": "workspace:*",
    "@fluentui/react-components": "^9.46.0",
    "@fluentui/react-icons": "^2.0.224",
    "axios": "^1.6.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "office-addin-dev-certs": "^1.12.1",
    "office-addin-debugging": "^5.0.14",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
